rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "alper.bozbey@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin')
      );
    }

    // ===============================================================
    // Global Settings (Admin Payment Settings & Subscription Packages)
    // ===============================================================
    match /adminSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /subscriptionPackages/{packageId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Users Collection
    // ===============================================================
    match /users/{userId} {
      // Users can read their own profile. Admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile.
      allow create: if isOwner(userId) && request.resource.data.role != 'Admin';
      
      // Users can update their own profile (but not their role). Admins can update anything.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      
      // Only admins can delete users.
      allow delete: if isAdmin();

      // ===============================================================
      // Tenant Subcollections
      // ===============================================================
      match /products/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /customers/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /invoices/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /tickets/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /accounts/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /brands/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /companySettings/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
